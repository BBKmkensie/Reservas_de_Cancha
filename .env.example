# Copia este archivo como .env y completa con tus datos.
# No subas el archivo .env a GitHub (contiene contraseñas).

# Base de datos (PostgreSQL local)
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=tu_contraseña
# DB_DATABASE=proyecto_taller
# DB_SSL=false

# Base de datos (PostgreSQL en Azure)
# DB_HOST=tu-servidor.postgres.database.azure.com
# DB_PORT=5432
# DB_USERNAME=administrador@tu-servidor
# DB_PASSWORD=tu_contraseña
# DB_DATABASE=postgres
# DB_SSL=true

# Puerto del backend NestJS
PORT=3000
